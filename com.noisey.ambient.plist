<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.noisey.ambient</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/local/bin/noisey</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/tmp/noisey.stdout.log</string>
	<key>StandardErrorPath</key>
	<string>/tmp/noisey.stderr.log</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>RUST_LOG</key>
		<string>noisey=info</string>
	</dict>
</dict>
</plist>
